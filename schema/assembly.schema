[]
[]
{
  Operation [(Generate GenerationRequest)]
  GenerationOutcome [(Generated GenerationReport)]
  GenerationRequest { SourceRoot WorkspaceRoot ManifestPath GenerationMode }
  SourceRoot Path {| Display AsRef PartialEq |}
  WorkspaceRoot Path {| Display AsRef PartialEq |}
  ManifestPath Path {| Display AsRef PartialEq |}
  GenerationMode [Write Check]
  GenerationReport { GeneratedFiles }
  GeneratedFiles (Vector GeneratedFile)
  GeneratedFile { OutputPath ByteCount }
  OutputPath Path {| Display AsRef PartialEq |}
  ByteCount Integer {| Display PartialEq PartialOrd |}
  Manifest { OutputPath OutputKind OutputSurface Frontmatter OptionalSkills Modules }
  OutputKind [Markdown Nota Toml]
  OutputSurface [Workspace AgentsSkill ClaudeSkill ClaudeCommand CodexPrompt CodexCommand ClaudeAgent CodexAgent PiAgent]
  Frontmatter (Vector FrontmatterEntry)
  FrontmatterEntry { FrontmatterKey FrontmatterValue }
  FrontmatterKey String {| Display AsRef PartialEq |}
  FrontmatterValue [(Scalar FrontmatterScalar) (Sequence FrontmatterSequence)]
  FrontmatterScalar String {| Display AsRef PartialEq |}
  FrontmatterSequence (Vector FrontmatterScalar)
  ModulePath Path {| Display AsRef PartialEq |}
  Modules (Vector ModulePath)
  ActiveOutputs (Vector ActiveOutput)
  ActiveOutput [(Skill ActiveSkill) (Role ActiveRole)]
  ActiveSkill { OutputIdentifier ModuleIdentifier SkillCategory SkillTier SkillDescription TargetSurfaces }
  ActiveRole { OutputIdentifier ModuleIdentifier IncludedModules RoleDescription RoleTargetSurfaces }
  OutputIdentifier String {| Display AsRef PartialEq Ord |}
  ModuleIdentifier String {| Display AsRef PartialEq Ord |}
  IncludedModules (Vector ModuleIdentifier)
  RoleDescription String {| Display AsRef PartialEq |}
  RoleTargetSurfaces (Vector RoleTargetSurface)
  RoleTargetSurface [ClaudeAgent CodexAgent PiAgent]
  ModelCatalog (Vector ModelCatalogEntry)
  ModelCatalogEntry [(ChatGpt ChatGptModel) (Claude ClaudeModel)]
  ChatGptModel { ModelIdentifier PiProvider CapabilityTier SupportedEfforts }
  ClaudeModel { ModelIdentifier CapabilityTier SupportedEfforts }
  ModelIdentifier String {| Display AsRef PartialEq Ord |}
  PiProvider String {| Display AsRef PartialEq |}
  CapabilityTier [Standard Advanced Premier]
  SupportedEfforts (Vector EffortLevel)
  EffortLevel [Medium High Xhigh]
  RoleModelAssignments (Vector RoleModelAssignment)
  RoleModelAssignment { OutputIdentifier ChatGptModelAssignment ClaudeModelAssignment }
  ChatGptModelAssignment { ModelIdentifier EffortLevel }
  ClaudeModelAssignment { ModelIdentifier EffortLevel }
  RoleOptionalSkills (Vector RoleOptionalSkill)
  RoleOptionalSkill { OutputIdentifier OptionalSkills }
  OptionalSkills (Vector OutputIdentifier)
  RoleCurricula (Vector RoleCurriculum)
  RoleCurriculum { CurriculumIdentifier AssignedRoles IncludedModules OptionalSkills AllowedLeafRoles }
  CurriculumIdentifier String {| Display AsRef PartialEq Ord |}
  AssignedRoles (Vector OutputIdentifier)
  NestedRoleRelations (Vector NestedRoleRelation)
  NestedRoleRelation { OutputIdentifier NestedRoleMinimumModels AllowedLeafRoles }
  NestedRoleMinimumModels (Vector NestedRoleMinimumModel)
  NestedRoleMinimumModel { RoleTargetSurface ModelIdentifier EffortLevel }
  AllowedLeafRoles (Vector OutputIdentifier)
  ModuleDependencies (Vector ModuleDependency)
  UniversalRoleModules (Vector ModuleIdentifier)
  ModuleDependency { ModuleIdentifier ModulePath DependencyModules ModuleKind }
  ModuleKind [RuntimeSkill RoleSource RoleComposition]
  DependencyModules (Vector ModuleIdentifier)
  TargetModuleInsertions (Vector TargetModuleInsertion)
  TargetModuleInsertion { ModuleIdentifier OutputSurface IncludedModules }
  GeneratedRoleOutputs (Vector OutputPath)
  SkillRoster { ArchiveRoot SkillModules EntryPoints }
  ArchiveRoot Path {| Display AsRef PartialEq |}
  SkillModules (Vector SkillModule)
  SkillModule { ModuleName ModulePath ModuleLifecycle EmissionPolicy TargetSurfaces }
  ModuleName String {| Display AsRef PartialEq |}
  ModuleLifecycle [(Active SkillMetadata) (Archived ArchivePath) Deleted]
  ArchivePath Path {| Display AsRef PartialEq |}
  SkillMetadata { SkillCategory SkillTier SkillDescription }
  SkillCategory [Architecture Craft Programming Workflow Meta]
  SkillTier [Apex Keystroke Topic Mechanism]
  SkillDescription String {| Display AsRef PartialEq |}
  EmissionPolicy [FirstClassSkill InternalOnly NoEmission]
  TargetSurfaces (Vector TargetSurface)
  TargetSurface [AgentsSkill ClaudeSkill]
  EntryPoints (Vector EntryPoint)
  EntryPoint { ModuleName EntryPointExtras }
  EntryPointExtras (Vector EntryPointExtra)
  EntryPointExtra { ExtraSurface ExtraModulePath }
  ExtraSurface [ClaudeCommand CodexPrompt CodexCommand]
  ExtraModulePath Path {| Display AsRef PartialEq |}
}
